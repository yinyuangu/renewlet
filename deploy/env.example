# ------------------------------------------------------------
# 一键 Docker 部署配置（Renewlet）
# ------------------------------------------------------------

# 对外服务端口。容器内部始终监听 3000。
PORT="3000"

# 镜像来源。默认使用 Docker Hub；如果 Docker Hub 不可用，可切换到 GHCR：
# RENEWLET_IMAGE="ghcr.io/zhiyingzzhou/renewlet:latest"
RENEWLET_IMAGE="zhiyingzzhou/renewlet:latest"

# Go 运行时软内存上限。小型 VPS/NAS 部署通常 128MiB 足够。
GOMEMLIMIT="128MiB"
MEM_LIMIT="256m"

# 容器时区。业务提醒时间仍按每个用户在应用内设置的时区计算。
TZ="Asia/Shanghai"

# 应用对外 URL，用于通知和密码重置邮件链接。
# 反向代理部署时，后续应改为你的 HTTPS 域名。
APP_URL="http://localhost:3000"

# 首次安装时由 deploy/docker-deploy.sh 生成。
# PB_ENCRYPTION_KEY 必须正好 32 个字符；不要随意轮换。
PB_ENCRYPTION_KEY=""
# CRON_SECRET 是外部通知 cron 调用使用的 Bearer token。
CRON_SECRET=""

# 可选：启用 PocketBase 密码重置邮件。
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="smtp-user"
# SMTP_PASSWORD="smtp-password"
# SMTP_FROM="Renewlet <noreply@example.com>"
# SMTP_TLS="false"

# 可选：启用 PocketBase 自动备份，例如每天 03:00 执行并保留 7 份。
# BACKUPS_CRON="0 3 * * *"
# BACKUPS_CRON_MAX_KEEP="7"

# 内置通知调度器。普通 Docker/VPS 托管应保持启用。
NOTIFICATION_SCHEDULER_ENABLED="true"
NOTIFICATION_SCHEDULER_CRON="* * * * *"
NOTIFICATION_CRON_WINDOW_MINUTES="2"
NOTIFICATION_MAX_RETRIES="3"
NOTIFICATION_STALE_SENDING_MINUTES="15"

# 可选：GitHub Release 和内置图标库版本检查 token。公开仓库可匿名检查；共享出口触发 API 限流时可配置只读 token。
# RENEWLET_GITHUB_TOKEN=""

# 数据存储在 ./data，并挂载到容器内的 /pb_data。
