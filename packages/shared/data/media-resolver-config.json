{
  "builtInProviders": [
    {
      "provider": "thesvg",
      "cdnBase": "https://testingcf.jsdelivr.net/gh/glincker/thesvg@main",
      "github": { "owner": "glincker", "repo": "thesvg", "branch": "main", "latestRelease": true },
      "preferredVariants": ["default", "color"]
    },
    {
      "provider": "selfhst",
      "cdnBase": "https://testingcf.jsdelivr.net/gh/selfhst/icons@main",
      "github": { "owner": "selfhst", "repo": "icons", "branch": "main", "latestRelease": false },
      "preferredVariants": ["default", "light", "dark"]
    },
    {
      "provider": "dashboardIcons",
      "cdnBase": "https://testingcf.jsdelivr.net/gh/homarr-labs/dashboard-icons@main",
      "github": { "owner": "homarr-labs", "repo": "dashboard-icons", "branch": "main", "latestRelease": false },
      "preferredVariants": ["default", "light", "dark"]
    }
  ],
  "auto": {
    "planSuffixWords": ["pro", "plus", "premium", "plan", "subscription", "monthly", "yearly", "annual"]
  },
  "search": {
    "minReducedQueryLength": 3,
    "modifierSuffixWords": ["pro", "plus", "premium", "plan", "subscription", "monthly", "yearly", "annual", "startup", "live", "free", "team", "teams", "business", "enterprise", "personal", "student", "family"]
  },
  "candidateGroups": {
    "searchFaviconReserve": 4
  },
  "limits": {
    "defaultCandidates": 32,
    "maxCandidates": 48,
    "maxItems": 100,
    "maxCandidateDomains": 16
  },
  "rateLimit": {
    "defaultMaxRequests": 30,
    "defaultWindowMs": 60000
  },
  "scores": {
    "exact": 1,
    "prefix": 0.9,
    "contains": 0.7,
    "allParts": 0.55,
    "subsequence": 0.35,
    "slugExactBoost": 0.3,
    "slugPrefixBoost": 0.1,
    "strongThreshold": 0.9,
    "mediumThreshold": 0.7
  },
  "favicon": {
    "fallbackTlds": {
      "logo": ["com", "io", "co", "app", "org"],
      "icon": ["com", "io", "co"]
    },
    "providers": [
      { "provider": "site", "urlTemplate": "https://{domain}/favicon.ico" },
      { "provider": "site", "urlTemplate": "https://{domain}/apple-touch-icon.png" },
      { "provider": "google-s2", "urlTemplate": "https://www.google.com/s2/favicons?domain={domain}&sz=128" },
      { "provider": "duckduckgo", "urlTemplate": "https://icons.duckduckgo.com/ip3/{domain}.ico" }
    ],
    "knownDomains": {
      "netflix": "netflix.com",
      "spotify": "spotify.com",
      "youtube": "youtube.com",
      "github": "github.com",
      "notion": "notion.so",
      "figma": "figma.com",
      "slack": "slack.com",
      "discord": "discord.com",
      "dropbox": "dropbox.com",
