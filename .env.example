# ------------------------------------------------------------
# 自托管配置（Renewlet Go + Vite + PocketBase）
# ------------------------------------------------------------

# 对外端口；容器内固定监听 3000。
PORT="3000"

# Go 运行时软内存上限。低内存机器建议保持 128MiB，容器上限先给 256m。
GOMEMLIMIT="128MiB"
MEM_LIMIT="256m"

# 容器时区，仅影响日志和少量本地时间展示；业务时间仍以用户设置为准。
TZ="Asia/Shanghai"

# 对外访问地址，用于 PocketBase 邮件链接。
APP_URL="http://localhost:3000"

# 可选：必须正好 32 个字符，用于加密 PocketBase settings 中的敏感字段。
# 源码本地开发可以留空；生产部署建议设置且不要随意轮换。
# 示例：openssl rand -hex 16
PB_ENCRYPTION_KEY=""

# 可选：配置后 PocketBase 原生密码找回邮件才会启用。
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="smtp-user"
# SMTP_PASSWORD="smtp-password"
# SMTP_FROM="Renewlet <noreply@example.com>"
# SMTP_TLS="false"

# 可选：PocketBase 自动备份 cron，例如每天 03:00 保留最近 7 份。
# BACKUPS_CRON="0 3 * * *"
# BACKUPS_CRON_MAX_KEEP="7"

# 内置通知调度器默认开启，每分钟检查一次用户本地通知时间。
# 是否启用内置通知调度器；设为 "false" 时不注册通知 cron。
NOTIFICATION_SCHEDULER_ENABLED="true"
# 外部平台 Cron 调用 /api/cron/notifications 时使用；只用内置调度器可留空。
# 示例：openssl rand -base64 32
CRON_SECRET=""
# 通知调度器的 cron 表达式；默认每分钟运行一次。
NOTIFICATION_SCHEDULER_CRON="* * * * *"
# 用户本地提醒时间的命中窗口，单位分钟；默认允许计划时间后 2 分钟内发送。
NOTIFICATION_CRON_WINDOW_MINUTES="2"
# 失败通知任务的最大重试次数；设为 0 时不重试失败任务。
NOTIFICATION_MAX_RETRIES="3"
# 任务处于 sending 状态超过多少分钟视为卡住并允许重新处理；最小值为 1。
NOTIFICATION_STALE_SENDING_MINUTES="15"

# 可选：GitHub Release 版本检查 token。公开仓库可匿名检查；共享出口触发 API 限流时可配置只读 token。
# RENEWLET_GITHUB_TOKEN=""

# 数据目录固定为 /pb_data，由 docker-compose 的 named volume 持久化（PocketBase）。
# 首次启动后访问 http://localhost:3000/setup 创建第一个管理员用户；如果 PocketBase 还没有真实 superuser，该账号也会成为 PB Admin UI 初始账号。
